      "id": "a1b2c3d4-0021-0021-0021-000000000021",
      "name": "Contar Mensajes Hoy",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1920, 0]
    },
    {
      "parameters": {
        "jsCode": "// Cuenta del header Content-Range de Supabase\nconst headers = $input.first().json.headers || {};\nconst contentRange = headers['content-range'] || '';\nconst match = contentRange.match(/\\/(\\d+)$/);\nconst count = match ? parseInt(match[1]) : 0;\n\n// Datos del mensaje: prioriza transcripción de audio si existe\nconst baseData = $('Parsear Mensaje WA').first().json;\nlet textContent = baseData.textContent;\ntry {\n  const audio = $('Unificar Transcripción').first().json;\n  if (audio && audio.textContent) textContent = audio.textContent;\n} catch(e) {}\n\nreturn [{ json: { ...baseData, textContent, mensajesHoy: count, limitAlcanzado: count >= 10 } }];"
      },
