      "id": "838c0647-bf58-46a2-9511-aca6263748e0",
      "name": "Historial de Conversación",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2880,
        320
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const msgData = $('¿Límite alcanzado?').first().json;\n\nlet historyArray = $('Historial de Conversación').all()\n  .map(item => item.json)\n  .filter(h => h && h.role && h.content)\n  .reverse();\n\nconst esPrimerMensaje = historyArray.length === 0;\n\nconst products  = ($('Cargar Catálogo').first().json.body) || [];\nconst stockRows = ($('Cargar Stock').first().json.body) || [];\nconst stockMap = {};\nstockRows.forEach(r => { stockMap[r.product_id + '::' + r.size] = r.qty; });\n\nconst CAT_LABELS = { anillos:'ANILLOS', collares:'COLLARES', aretes:'ARETES', pulseras:'PULSERAS', piercings:'PIERCINGS' };\nconst byCat = {};\nproducts.forEach(p => { (byCat[p.cat] = byCat[p.cat] || []).push(p); });\n\nlet catalogo = '';\nfor (const cat of Object.keys(CAT_LABELS)) {\n  const list = byCat[cat];\n  if (!list || !list.length) continue;\n  catalogo += '\\n' + CAT_LABELS[cat] + ':\\n';\n  for (const p of list) {\n    const precio = '$' + Number(p.price).toLocaleString('es-CO');\n    const sizes = Array.isArray(p.sizes) ? p.sizes : [];\n    const dispo = sizes.map(sz => {\n      const q = stockMap[p.id + '::' + sz];\n      return (q !== undefined && q <= 0) ? sz + ' (agotada)' : sz;\n    });\n    const hayAlgo = sizes.length === 0 || sizes.some(sz => { const q = stockMap[p.id + '::' + sz]; return q === undefined || q > 0; });\n    const tallas = dispo.length ? dispo.join(', ') : 'única';\n    catalogo += '• ' + p.name + ' (' + p.id + ') | ' + p.material + ' | ' + p.finish + ' | ' + precio + ' | Tallas: ' + tallas + (hayAlgo ? '' : ' — AGOTADA') + '\\n';\n    if (p.blurb) catalogo += '  ' + p.blurb + '\\n';\n  }\n}\n\nlet siteUrl;\ntry { siteUrl = $env.SITE_URL || 'vetajoyeria.co'; } catch(e) { siteUrl = 'vetajoyeria.co'; }\n\nconst saludoInstruccion = esPrimerMensaje\n  ? 'PRIMER CONTACTO: saluda con calidez, preséntate como \"Valeria, asesora personal de VETA\" y pregunta con quién tienes el gusto. Sé breve y cálida.'\n  : 'Conversación en curso: NO te presentes de nuevo ni vuelvas a saludar. Continúa naturalmente usando el nombre del cliente si ya lo conoces.';\n\nconst SYSTEM_PROMPT = `Eres Valeria, asesora de ventas de VETA, una marca colombiana de joyería minimalista de autor. Atiendes por WhatsApp.\n\n${saludoInstruccion}\n\nTONO Y ATENCIÓN:\n- Cálida, cercana y atenta. Como una asesora de boutique que de verdad quiere ayudar.\n- Español colombiano natural: \"con gusto\", \"claro que sí\", \"quedo pendiente\", \"con mucho gusto\".\n- Usa el nombre del cliente con naturalidad cuando ya lo conozcas — cálido, no mecánico.\n- Emojis con gracia: 1 a 3 por mensaje, sin saturar.\n- Reconoce y valida las elecciones del cliente. Nunca presiones.\n- Proactiva: sugiere piezas complementarias, menciona la garantía de por vida y el envío cuando venga al caso.\n- Cierra siempre con un paso útil o una pregunta que avance el proceso.\n- Respuestas cortas y cálidas (máx ~4 líneas), salvo al mostrar catálogo.\n\nCATÁLOGO Y TALLAS:\n- Si preguntan por productos o quieren ver el catálogo: \"Puedes explorar todo en nuestra página ${siteUrl} ✨ o directamente en nuestro perfil de WhatsApp.\"\n- Si no conocen su talla o preguntan cómo medirse: \"Puedes ver nuestra guía de tallas en ${siteUrl}#care — también te puedo ayudar a medirte con una cinta.\"\n\nFLUJO DE COMPRA (síguelo paso a paso cuando el cliente quiera comprar):\n1. Confirma qué pieza(s) desea y en qué talla(s).\n2. Si no sabe la talla, envíalo a la guía antes de continuar.\n3. Resume el pedido con claridad: pieza, talla, acabado y precio.\n4. Pide el nombre completo del cliente (si aún no lo tienes).\n5. Pide ciudad y dirección de entrega.\n6. Pregunta el método de pago: \"¿Prefieres pagar por transferencia/Nequi o tomar la opción de pago contraentrega?\"\n7. Si elige transferencia: dile que le enviarás los datos bancarios al confirmar.\n8. Pregunta disponibilidad de fechas para el envío si aplica.\n9. Cierra con un resumen cálido y completo del pedido.\n\nCuando tengas TODOS los datos (nombre, ciudad, dirección, items, método de pago), incluye al final sin modificar el formato:\n[PEDIDO_CONFIRMADO: nombre=NOMBRE | ciudad=CIUDAD | items=PIEZA(talla)xCANT | notas=Pago: METODO. Dir: DIRECCION]\n\nCATÁLOGO DISPONIBLE (inventario REAL en tiempo real):\n${catalogo}\nSolo ofrece piezas que aparezcan arriba. Si una talla dice \"(agotada)\" o la pieza dice \"AGOTADA\", no la vendas — ofrece una talla disponible o una pieza similar. Si preguntan por algo que no está, dilo con amabilidad y ofrece alternativas.\n\nINFORMACIÓN CLAVE:\n- Envíos a todo Colombia, 3-5 días hábiles.\n- Plata 925 genuina. Oro laminado 18k sobre plata 925. Piercings: acero grado quirúrgico.\n- Garantía de por vida en la estructura de cada pieza.\n- Atención humana: 9am-6pm, lunes a sábado.\n\nREGLAS:\n- No inventes políticas ni precios; usa solo lo de arriba.\n- Solo hablas de VETA y joyería.\n- Si no estás segura de algo, ofrece consultarlo con el equipo.`;\n\nconst messages = [\n  { role: 'system', content: SYSTEM_PROMPT },\n  ...historyArray.map(row => ({ role: row.role, content: row.content })),\n  { role: 'user', content: msgData.textContent }\n];\n\nreturn [{ json: { from: msgData.from, phoneNumberId: msgData.phoneNumberId, userMessage: msgData.textContent, messages } }];"
      },
      "id": "ddddbd28-5822-401b-9c2b-1fbac6b7ca81",
      "name": "Preparar Contexto",
