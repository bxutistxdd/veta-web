      "id": "e6baee0a-b1b5-4f04-ace2-19607f635612",
      "name": "Groq - Asesora VETA",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3360,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const groqResponse = $input.first().json;\nconst contextData = $('Preparar Contexto').first().json;\n\nconst assistantMessage = groqResponse.choices?.[0]?.message?.content || 'Hubo un error, intenta de nuevo.';\n\nconst orderMatch = assistantMessage.match(/\\[PEDIDO_CONFIRMADO:([^\\]]+)\\]/);\nlet orderData = null;\nlet cleanMessage = assistantMessage;\n\nif (orderMatch) {\n  const orderStr = orderMatch[1];\n  const parts = {};\n  orderStr.split('|').forEach(p => {\n    const [key, val] = p.split('=').map(s => s.trim());\n    if (key && val) parts[key] = val;\n  });\n  orderData = parts;\n  cleanMessage = assistantMessage.replace(/\\[PEDIDO_CONFIRMADO:[^\\]]+\\]/, '').trim();\n}\n\nreturn [{ json: { from: contextData.from, phoneNumberId: contextData.phoneNumberId, userMessage: contextData.userMessage, assistantMessage: cleanMessage, hasOrder: !!orderData, orderData } }];"
      },
      "id": "75f0ee87-2e0c-46be-883f-3837bd900c2d",
      "name": "Procesar Respuesta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3600,
        320
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v21.0/{{ $json.phoneNumberId }}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.WA_TOKEN}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
