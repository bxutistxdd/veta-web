      "id": "af8d6942-4237-4555-a692-52ebe97fed4c",
      "name": "Responder 200 OK a Meta",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        240,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\ntry {\n  const message = body.entry?.[0]?.changes?.[0]?.value?.messages?.[0];\n  if (!message) return [{ json: { skip: true } }];\n  const meta = body.entry[0].changes[0].value.metadata;\n  const from = message.from;\n  const type = message.type;\n  const phoneNumberId = meta.phone_number_id;\n  let textContent = '';\n  let mediaId = null;\n  let mediaType = 'text';\n  if (type === 'text') {\n    textContent = message.text.body;\n    mediaType = 'text';\n  } else if (type === 'audio' || type === 'voice') {\n    mediaId = message.audio?.id || message.voice?.id;\n    mediaType = 'audio';\n  } else if (type === 'image') {\n    mediaId = message.image.id;\n    textContent = message.image.caption || '[imagen]';\n    mediaType = 'text';\n  } else {\n    textContent = '[Archivo no soportado]';\n    mediaType = 'text';\n  }\n  const RESET_KEYWORDS = ['nuevo chat', 'reiniciar'];\n  const isReset = type === 'text' && RESET_KEYWORDS.some(k => textContent.toLowerCase().trim() === k);\n  const finalText = isReset ? 'Hola' : textContent;\n  return [{ json: { from, type, textContent: finalText, mediaId, mediaType, phoneNumberId, skip: false, isReset } }];\n} catch (err) {\n  return [{ json: { skip: true } }];\n}"
      },
      "id": "1ae7bd57-6afd-482b-8659-02fa96b397a2",
