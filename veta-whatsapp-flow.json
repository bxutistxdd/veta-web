    {
      "parameters": {
        "jsCode": "const inputData = $input.first().json;\nconst baseData = $('Parsear Mensaje WA').first().json;\n\n// Audio llega con .text (respuesta de Groq Whisper)\n// Texto llega con .textContent ya seteado\nconst textContent = inputData.text || inputData.textContent || '';\n\nreturn [{ json: { ...baseData, textContent } }];"
      },
