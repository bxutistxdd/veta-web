        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"messaging_product\":\"whatsapp\",\"to\":\"{{$env.WA_NOTIFY_NUMBER}}\",\"type\":\"text\",\"text\":{\"body\":\"\\ud83d\\udc64 *Cliente listo para asesor*\\n\\nN\\u00famero: +{{ $json.from }}\\nMensajes hoy: {{ $json.mensajesHoy }}/10\\n\\nYa le avisamos que lo atender\\u00e1s en unos minutos.\"}}",
