      "id": "e6baee0a-b1b5-4f04-ace2-19607f635612",
      "name": "Groq - Asesora VETA",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3360,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const groqResponse = $input.first().json;\nconst contextData = $('Preparar Contexto').first().json;\n\nconst assistantMessage = groqResponse.choices?.[0]?.message?.content || 'Hubo un error, intenta de nuevo.';\n\n// Regex flexible: con o sin corchetes, con o sin espacios alrededor del tag\nconst orderMatch = assistantMessage.match(/\\[?PEDIDO_CONFIRMADO:\\s*([^\\]\\n]+?)\\]?(?=\\s*$|\\n)/m)\n  || assistantMessage.match(/\\[?PEDIDO_CONFIRMADO:\\s*([^\\]]+?)\\]?/);\n\nlet orderData = null;\nlet cleanMessage = assistantMessage\n  .replace(/\\[?PEDIDO_CONFIRMADO:[^\\]\\n]*\\]?/g, '')\n  .trim();\n\nif (orderMatch) {\n  const parts = {};\n  orderMatch[1].split('|').forEach(p => {\n    const idx = p.indexOf('=');\n    if (idx > 0) {\n      const key = p.slice(0, idx).trim();\n      const val = p.slice(idx + 1).trim();\n      if (key && val) parts[key] = val;\n    }\n  });\n\n  // Validar que estén todos los campos obligatorios\n  const nombre = parts['nombre'] || '';\n  const ciudad = parts['ciudad'] || '';\n  const items  = parts['items']  || '';\n  const notas  = parts['notas']  || '';\n\n  const tieneDir   = notas.toLowerCase().includes('dir:') && notas.replace(/pago:[^.]+\\.?/i,'').replace(/dir:/i,'').trim().length > 3;\n  const tienePago  = notas.toLowerCase().includes('pago:') && notas.replace(/pago:/i,'').split('.')[0].trim().length > 1;\n\n  if (nombre.length > 1 && ciudad.length > 1 && items.length > 1 && tieneDir && tienePago) {\n    orderData = parts;\n  }\n  // Si faltan datos, cleanMessage ya está sin el tag — el bot seguirá la conversación\n}\n\nreturn [{ json: {\n  from: contextData.from,\n  phoneNumberId: contextData.phoneNumberId,\n  userMessage: contextData.userMessage,\n  assistantMessage: cleanMessage,\n  hasOrder: !!orderData,\n  orderData\n} }];"
      },
