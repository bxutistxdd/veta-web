    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\ntry {\n  const message = body.entry?.[0]?.changes?.[0]?.value?.messages?.[0];\n  if (!message) return [{ json: { skip: true } }];\n  const meta = body.entry[0].changes[0].value.metadata;\n  const from = message.from;\n  const type = message.type;\n  const phoneNumberId = meta.phone_number_id;\n  let textContent = '';\n  let mediaId = null;\n  let mediaType = 'text';\n  if (type === 'text') {\n    textContent = message.text.body;\n    mediaType = 'text';\n  } else if (type === 'audio' || type === 'voice') {\n    mediaId = message.audio?.id || message.voice?.id;\n    mediaType = 'audio';\n  } else if (type === 'image') {\n    mediaId = message.image.id;\n    textContent = message.image.caption || '[imagen]';\n    mediaType = 'text';\n  } else {\n    textContent = '[Archivo no soportado]';\n    mediaType = 'text';\n  }\n  return [{ json: { from, type, textContent, mediaId, mediaType, phoneNumberId, skip: false } }];\n} catch (err) {\n  return [{ json: { skip: true } }];\n}"
      },
