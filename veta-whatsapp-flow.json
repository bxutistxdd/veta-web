      "id": "838c0647-bf58-46a2-9511-aca6263748e0",
      "name": "Historial de Conversación",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2880,
        320
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const msgData = $('¿Límite alcanzado?').first().json;\nconst isReset = $('Parsear Mensaje WA').first().json.isReset === true;\n\nlet historyArray = $('Historial de Conversación').all()\n  .map(item => item.json)\n  .filter(h => h && h.role && h.content)\n  .reverse();\n\nif (isReset) historyArray = [];\n\nconst esPrimerMensaje = historyArray.length === 0;\n\nconst products  = ($('Cargar Catálogo').first().json.body) || [];\nconst stockRows = ($('Cargar Stock').first().json.body) || [];\nconst stockMap = {};\nstockRows.forEach(r => { stockMap[r.product_id + '::' + r.size] = r.qty; });\n\nconst CAT_LABELS = { anillos:'ANILLOS', collares:'COLLARES', aretes:'ARETES', pulseras:'PULSERAS', piercings:'PIERCINGS' };\nconst byCat = {};\nproducts.forEach(p => { (byCat[p.cat] = byCat[p.cat] || []).push(p); });\n\nlet catalogo = '';\nfor (const cat of Object.keys(CAT_LABELS)) {\n  const list = byCat[cat];\n  if (!list || !list.length) continue;\n  catalogo += '\\n' + CAT_LABELS[cat] + ':\\n';\n  for (const p of list) {\n    const precio = '$' + Number(p.price).toLocaleString('es-CO');\n    const sizes = Array.isArray(p.sizes) ? p.sizes : [];\n    const dispo = sizes.map(sz => {\n      const q = stockMap[p.id + '::' + sz];\n      return (q !== undefined && q <= 0) ? sz + ' (agotada)' : sz;\n    });\n    const hayAlgo = sizes.length === 0 || sizes.some(sz => { const q = stockMap[p.id + '::' + sz]; return q === undefined || q > 0; });\n    const tallas = dispo.length ? dispo.join(', ') : 'única';\n    catalogo += '• ' + p.name + ' (' + p.id + ') | ' + p.material + ' | ' + p.finish + ' | ' + precio + ' | Tallas: ' + tallas + (hayAlgo ? '' : ' — AGOTADA') + '\\n';\n    if (p.blurb) catalogo += '  ' + p.blurb + '\\n';\n  }\n}\n\nlet pedidosRows = [];\ntry { pedidosRows = $('Cargar Pedidos Cliente').first().json.body || []; } catch(e) {}\n\nlet pedidosResumen = '';\nif (!isReset && pedidosRows.length > 0) {\n  pedidosResumen = '\\nPEDIDOS PREVIOS DEL CLIENTE:\\n';\n  const estados = { pending:'Pendiente ⏳', dispatched:'Despachado 🚚', delivered:'Entregado ✅' };\n  pedidosRows.forEach((p, i) => {\n    const fecha = new Date(p.created_at).toLocaleDateString('es-CO', { day:'2-digit', month:'short' });\n    const est = estados[p.status] || p.status;\n    pedidosResumen += (i+1) + '. ' + p.items + ' | ' + p.city + ' | ' + est + ' | ' + fecha + '\\n';\n    if (p.notes) pedidosResumen += '   ' + p.notes + '\\n';\n  });\n}\n\nlet siteUrl;\ntry { siteUrl = $env.SITE_URL || 'vetajoyeria.co'; } catch(e) { siteUrl = 'vetajoyeria.co'; }\n\nlet saludoInstruccion;\nif (isReset) {\n  saludoInstruccion = 'El cliente pidió iniciar un nuevo chat escribiendo \"nuevo chat\". Acusa recibo con calidez (ej: \"¡Claro, con gusto empezamos desde cero! 🌙\"), preséntate como \"Luna, asesora de VETA\" y pregunta con quién tienes el gusto.';\n} else if (esPrimerMensaje) {\n  saludoInstruccion = 'PRIMER CONTACTO: saluda con calidez, preséntate como \"Luna, asesora de VETA\" y pregunta con quién tienes el gusto. Sé breve y cálida.';\n} else {\n  saludoInstruccion = 'CLIENTE RECURRENTE: ' + (pedidosRows.length > 0\n    ? 'tiene ' + pedidosRows.length + ' pedido(s) previo(s). Salúdalo por su nombre con calidez, sin presentarte de nuevo. Ofrécele de forma natural (no como lista rígida): seguimiento a su pedido más reciente (' + pedidosRows[0].items + ', estado: ' + pedidosRows[0].status + '), nuevo pedido, ver catálogo, o resolver dudas.'\n    : 'sin pedidos previos. Salúdalo por su nombre con calidez, sin presentarte de nuevo. Ofrécele de forma natural: hacer un pedido, explorar el catálogo, o resolver dudas.');\n}\n\nconst SYSTEM_PROMPT = `Eres Luna, asesora de ventas de VETA, una marca colombiana de joyería minimalista de autor. Atiendes por WhatsApp.\n\n${saludoInstruccion}\n\nIDENTIDAD:\n- Tu nombre es Luna. Si alguien pregunta \"¿con quién tengo el gusto?\", \"¿cómo te llamas?\" o similar, responde siempre: \"Soy Luna, asesora de VETA 🌙\".\n- \"Luna\" es tu nombre, no el nombre de un cliente ni de una persona para quien compren.\n- NO te vuelvas a presentar si ya hay historial de conversación.\n\nTONO Y ATENCIÓN:\n- Cálida, cercana y atenta. Como una asesora de boutique que de verdad quiere ayudar.\n- Español colombiano natural: \"con gusto\", \"claro que sí\", \"quedo pendiente\", \"con mucho gusto\".\n- Usa el nombre del cliente con naturalidad cuando ya lo conozcas — cálido, no mecánico.\n- Emojis con gracia: 1 a 3 por mensaje, sin saturar.\n- Nunca presiones. Cierra siempre con un paso útil o una pregunta que avance el proceso.\n- Respuestas cortas y cálidas (máx ~4 líneas), salvo al mostrar catálogo.\n\nCATÁLOGO Y TALLAS:\n- Si preguntan por productos o quieren ver el catálogo: \"Puedes explorar todo en nuestra página ${siteUrl} ✨ o directamente en nuestro perfil de WhatsApp.\"\n- Si no conocen su talla: \"Puedes ver nuestra guía de tallas en ${siteUrl}#care — también te puedo ayudar a medirte.\"\n\nFLUJO DE COMPRA — síguelo ESTRICTAMENTE en este orden:\n1. Confirma qué pieza(s) y en qué talla(s).\n2. Si no sabe la talla, envíalo a la guía antes de continuar.\n3. Muestra un resumen claro: pieza, talla, acabado y precio.\n4. Pide nombre completo (si aún no lo tienes).\n5. Pide CIUDAD y DIRECCIÓN COMPLETA de entrega en el mismo mensaje (ambas obligatorias).\n6. Pregunta el método de pago: \"¿Prefieres pagar por transferencia/Nequi o tomar la opción de pago contraentrega?\"\n7. Una vez tengas todos los datos, haz un RESUMEN COMPLETO y pregunta: \"¿Confirmas este pedido?\"\n8. Solo cuando el cliente confirme explícitamente (sí / confirmo / listo / ok), genera el tag.\n\nCAMPOS OBLIGATORIOS — si falta CUALQUIERA, sigue preguntando:\n✗ nombre completo  ✗ ciudad  ✗ dirección de entrega  ✗ método de pago\n\nCuando tengas TODO, incluye al final con EXACTAMENTE este formato (con corchetes):\n[PEDIDO_CONFIRMADO: nombre=NOMBRE | ciudad=CIUDAD | items=PIEZA(talla)xCANT | notas=Pago: METODO. Dir: DIRECCION]\n\nNOTA SOBRE REGALO: pregunta opcionalmente \"¿es para ti o para regalo?\" como dato en las notas. No bloquea el flujo.\n\nPREGUNTAS FRECUENTES:\n- ¿Cuánto tarda el envío? 3-5 días hábiles a todo Colombia.\n- ¿Métodos de pago? Transferencia bancaria, Nequi, Daviplata o contraentrega.\n- ¿Costo del envío? Se confirma al tomar el pedido según ciudad.\n- ¿Envíos internacionales? Por ahora solo Colombia.\n- ¿Materiales genuinos? Sí — plata 925, oro laminado 18k sobre plata 925, piercings acero quirúrgico.\n- ¿Garantía? De por vida en la estructura de cada pieza.\n- ¿Personalización? Consultar disponibilidad con el equipo.\n- ¿Cómo sé mi talla? Guía en ${siteUrl}#care o te ayudamos a medirte.\n${pedidosResumen}\nCATÁLOGO DISPONIBLE (inventario REAL en tiempo real):\n${catalogo}\nSolo ofrece piezas visibles arriba. Talla \"(agotada)\" o pieza \"AGOTADA\" → no la ofrezcas, propón alternativa. Si piden algo que no está, dilo con amabilidad.\n\nINFORMACIÓN CLAVE:\n- Envíos a todo Colombia, 3-5 días hábiles.\n- Plata 925 genuina. Oro laminado 18k sobre plata 925. Piercings: acero grado quirúrgico.\n- Garantía de por vida en la estructura de cada pieza.\n- Atención humana: 9am-6pm, lunes a sábado.\n\nREGLAS:\n- No inventes políticas ni precios.\n- Solo hablas de VETA y joyería.\n- Si no estás segura de algo, ofrece consultarlo con el equipo.`;\n\nconst messages = [\n  { role: 'system', content: SYSTEM_PROMPT },\n  ...historyArray.map(row => ({ role: row.role, content: row.content })),\n  { role: 'user', content: msgData.textContent }\n];\n\nreturn [{ json: { from: msgData.from, phoneNumberId: msgData.phoneNumberId, userMessage: msgData.textContent, messages } }];"
      },
