      "id": "af8d6942-4237-4555-a692-52ebe97fed4c",
      "name": "Responder 200 OK a Meta",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        240,
        208
      ]
