    {
      "parameters": {
        "jsCode": "const headers = $input.first().json.headers || {};\nconst contentRange = headers['content-range'] || '';\nconst match = contentRange.match(/\\/(\\d+)$/);\nconst count = match ? parseInt(match[1]) : 0;\n\n// Obtener datos del mensaje: audio usa Unificar Transcripción, texto usa Parsear Mensaje WA\nlet msgData;\ntry {\n  msgData = $('Unificar Transcripción').first().json;\n} catch(e) {\n  msgData = $('Parsear Mensaje WA').first().json;\n}\n\nreturn [{ json: { ...msgData, mensajesHoy: count, limitAlcanzado: count >= 10 } }];"
      },
