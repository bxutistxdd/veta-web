# Variables de entorno para los scripts de mantenimiento/deploy de VETA.
# Copia a .env (ignorado por git) o expórtalas en tu shell / usa `railway run`.
# NUNCA committear valores reales. Tras la fuga histórica, ROTAR todas estas.

# Postgres de n8n en Railway (deploy-n8n-chat.js, schema-check.js, etc.)
RAILWAY_PG_PASSWORD=

# WhatsApp Cloud API / Meta (test-waba.js, create-wa-templates.js, ...)
WA_TOKEN=
WABA_ID=
WA_PHONE_NUMER_ID=1216679024851056
WA_NOTIFY_NUMBER=

# Para validar la firma del webhook de Meta (B1) — App Secret de la app de Meta
APP_SECRET=

# Supabase (aplicar SQL contra prod)
SUPABASE_PG_URL=
